# Supabase 專案設定
# 在 Supabase Dashboard → Project Settings → API 取得
NEXT_PUBLIC_SUPABASE_URL=https://你的專案.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=你的_anon_public_key

# 注意：
# - 只用 anon key，service_role key 千萬別放在這裡或 commit 到 GitHub
# - .env.local 已被 .gitignore，不會被推上去
# - 改完 .env.local 要重啟 npm run dev 才會生效
